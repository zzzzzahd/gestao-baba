{
  "name": "gestao-baba",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate-icons": "bash generate-icons.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:pages": "vitest run src/__tests__/pages",
    "test:components": "vitest run src/__tests__/components",
    "test:hooks": "vitest run src/__tests__/hooks",
    "test:utils": "vitest run src/__tests__/utils",
    "test:services": "vitest run src/__tests__/services",
    "test:integration": "vitest run src/__tests__/integration",
    "test:security": "vitest run src/__tests__/security",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "npm test && npm run test:e2e",
    "setup:tests": "node -e \"console.log('Use: .\\\\setup-tests.ps1 (Windows) ou bash setup-tests.sh')\"",
    "report": "node scripts/generate-report.mjs",
    "report:open": "node scripts/test-and-report.mjs --open",
    "test:report": "node scripts/test-and-report.mjs",
    "test:report:coverage": "node scripts/test-and-report.mjs --coverage --open"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.39.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "lucide-react": "^0.294.0",
    "nanoid": "^5.0.7",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.1.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.4.16",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vitest": "^1.6.1"
  }
}
