# ═══════════════════════════════════════════════════════════════
# Draft Play — Variáveis de ambiente
# ═══════════════════════════════════════════════════════════════
# Como configurar (modo fácil):
#   1. Copie este arquivo:  cp .env.example .env
#      (Windows PowerShell): Copy-Item .env.example .env
#   2. Preencha os valores abaixo com os dados do seu projeto Supabase
#   3. Rode: npm run dev
#
# Onde achar as chaves:
#   Supabase → Project Settings → API
#   - Project URL  → VITE_SUPABASE_URL
#   - anon / public key → VITE_SUPABASE_PUBLISHABLE_KEY
# ═══════════════════════════════════════════════════════════════

# Obrigatórias (o app não sobe sem elas)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-anon-publica

# Opcionais
# Chave pública VAPID para notificações push (Supabase → Edge Functions / Web Push)
VITE_VAPID_PUBLIC_KEY=

# Sentry (monitoramento de erros) — deixe vazio em desenvolvimento local
VITE_SENTRY_DSN=

# Token do Sentry só no CI/deploy (nunca no frontend)
# SENTRY_AUTH_TOKEN=
